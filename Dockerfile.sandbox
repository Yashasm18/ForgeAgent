# A deliberately small, rootless runner for untrusted generated capabilities.
# Build: docker build -f Dockerfile.sandbox -t forgeagent-sandbox:local .
FROM python:3.12-slim

RUN useradd --create-home --uid 10001 --shell /usr/sbin/nologin foundry
WORKDIR /sandbox
COPY --chown=10001:10001 forgeagent/container_runner.py /sandbox/container_runner.py
USER 10001:10001
ENTRYPOINT ["python", "-I", "/sandbox/container_runner.py"]
